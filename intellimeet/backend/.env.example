# Server
PORT=5000
NODE_ENV=development
# Frontend is served from this same server (backend/app.js serves ../frontend),
# so CORS only matters if you run the frontend separately (e.g. on a different port).
# Use * for "any origin" during local dev, or set it to your real frontend URL in production.
CLIENT_URL=*

# MongoDB
# Local: mongodb://localhost:27017/intellimeet
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/intellimeet
MONGO_URI=mongodb://localhost:27017/intellimeet

# Auth
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Claude API (server-side only — never expose this key to the frontend)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
